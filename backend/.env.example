NODE_ENV=development
PORT=5000
API_PREFIX=/api

# Comma-separated allowed origins (web + POS desktop)
CLIENT_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5175,http://127.0.0.1:5175,tauri://localhost,http://tauri.localhost,https://tauri.localhost
# Optional single origin (fallback/compat)
CLIENT_ORIGIN=http://localhost:5173

# Optional: plain domain only (example: .dipdash.com). Keep empty for localhost.
COOKIE_DOMAIN=
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# Preferred token vars
ACCESS_TOKEN_SECRET=replace_with_a_strong_access_secret_min_16_chars
REFRESH_TOKEN_SECRET=replace_with_a_strong_refresh_secret_min_16_chars
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=14d
ACCESS_COOKIE_NAME=DND_ACCESS_TOKEN
REFRESH_COOKIE_NAME=DND_REFRESH_TOKEN

# Legacy-compatible aliases (optional)
JWT_ACCESS_SECRET=
JWT_ACCESS_EXPIRES_IN=
AUTH_COOKIE_NAME=

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=dip_and_dash
DATABASE_SSL=false

SEED_ADMIN_USERNAME=ansar
SEED_ADMIN_PASSWORD=Ansar@2026
SEED_ADMIN_FULL_NAME=Ansar Admin
