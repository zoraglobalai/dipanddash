NODE_ENV=production
PORT=8080
API_PREFIX=/api

# Add your frontend domain(s), comma-separated
CLIENT_ORIGINS=https://plankton-app-yol5u.ondigitalocean.app
CLIENT_ORIGIN=https://plankton-app-yol5u.ondigitalocean.app

# Cookies in production
COOKIE_DOMAIN=
COOKIE_SECURE=true
COOKIE_SAME_SITE=none

# JWT/Auth secrets
ACCESS_TOKEN_SECRET=
REFRESH_TOKEN_SECRET=
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=14d
ACCESS_COOKIE_NAME=DND_ACCESS_TOKEN
REFRESH_COOKIE_NAME=DND_REFRESH_TOKEN

# Neon / managed Postgres
DATABASE_URL=
DATABASE_SSL=true
DATABASE_SSL_REJECT_UNAUTHORIZED=false
# For first-ever deploy on an empty DB without full migrations, set true once, then revert to false
DB_SYNCHRONIZE=false
DB_LOGGING=false

# Optional seed values
SEED_ADMIN_USERNAME=ansar
SEED_ADMIN_PASSWORD=Ansar@2026
SEED_ADMIN_FULL_NAME=Ansar Admin
