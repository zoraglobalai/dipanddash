{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Dip and Dash POS",
  "version": "0.1.2",
  "identifier": "com.dipanddash.pos",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5175",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Dip & Dash POS",
        "width": 1440,
        "height": 900,
        "minWidth": 1200,
        "minHeight": 760,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:pos.db"]
    },
    "updater": {
      "active": true,
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEMwQUFENjNDOTA4REQ0NTQKUldSVTFJMlFQTmFxd0ZOSlN3dGJiK04yU01mclVBWlkrSUd5cmk4em1sNnRuelAzbWpqY3Q3TWMK",
      "endpoints": [
        "https://github.com/zoraglobalai/dipanddash/releases/latest/download/latest.json"
      ]
    }
  }
}
